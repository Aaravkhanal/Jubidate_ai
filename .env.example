# ═══════════════════════════════════════════════════════════════
# Jubidate AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Mock Mode ──
# Set true for zero-cost UI testing without hitting any APIs
MOCK_LLM_RESPONSES=false

# ==============================================================================
# PRIMARY INFERENCE PROVIDER — NVIDIA NIM
# All LLM inference routes through NVIDIA's OpenAI-compatible endpoint.
# Get your key at: https://build.nvidia.com
# ==============================================================================
NVIDIA_API_KEY=your_nvidia_api_key_here

# ==============================================================================
# GOOGLE CLOUD (STT/TTS ONLY — NOT USED FOR LLM INFERENCE)
# Optional. Powers Speech-to-Text and Text-to-Speech in the frontend.
# ==============================================================================
GOOGLE_API_KEY=your_google_api_key_here

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=6001
FRONTEND_ORIGIN=http://localhost:6001
DATABASE_PATH=backend/data/jubidate.db
LITELLM_TIMEOUT_SECONDS=120
