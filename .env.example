# ═══════════════════════════════════════════════════════════════
# Jubidate AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Mock Mode ──
# Set true for zero-cost UI testing without hitting any APIs
MOCK_LLM_RESPONSES=false

# ==============================================================================
# REQUIRED APIS
# At least ONE of the following LLM API keys is required to run the engine.
# ==============================================================================

# ── Google Gemini (REQUIRED/RECOMMENDED - FREE TIER) ──
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Vertex AI ──
VERTEX_AI_API_KEY=your_vertex_ai_api_key_here

# ── OpenAI (REQUIRED/OPTIONAL - PAID) ──
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================================================
# OPTIONAL APIS (NOT REQUIRED)
# ==============================================================================

# ── Groq (OPTIONAL - FREE TIER) ──
GROQ_API_KEY=your_groq_api_key_here

# ── Fireworks AI (OPTIONAL - PAID) ──
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ── MiniMax (OPTIONAL - PAID) ──
MINIMAX_API_KEY=your_minimax_api_key_here

# ── OpenRouter (OPTIONAL) ──
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=6001
FRONTEND_ORIGIN=http://localhost:6001
DATABASE_PATH=backend/data/jubidate.db
LITELLM_TIMEOUT_SECONDS=120
